<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dao.TroubleshootingDao">

    <select id="findByName" resultType="com.example.vo.TroubleshootingVo">
        select `troubleshooting`.* from `troubleshooting`
        where 1 = 1
        <if test="name != null and name != '' and name != 'all'">
            and `troubleshooting`.`name` like concat('%', #{name}, '%')
        </if>
        order by `troubleshooting`.`time` desc
    </select>

    <select id="findVoById" resultType="com.example.vo.TroubleshootingVo">
        select `troubleshooting`.* from `troubleshooting`
        where `troubleshooting`.id = #{id}
    </select>


</mapper>