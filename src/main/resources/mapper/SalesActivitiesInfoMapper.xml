<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dao.SalesActivitiesInfoDao">

    <select id="findByName" resultType="com.example.vo.SalesActivitiesInfoVo">
        select `sales_activities_info`.* from `sales_activities_info`
        where 1 = 1
        <if test="name != null and name != '' and name != 'all'">
            and `sales_activities_info`.`name` like concat('%', #{name}, '%')
        </if>
        order by `sales_activities_info`.`time` desc
    </select>

    <select id="findVoById" resultType="com.example.vo.SalesActivitiesInfoVo">
        select `sales_activities_info`.* from `sales_activities_info`
        where `sales_activities_info`.id = #{id}
    </select>


</mapper>