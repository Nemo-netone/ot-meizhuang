<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dao.ShopInfoDao">

    <select id="findByName" resultType="com.example.vo.ShopInfoVo">
        select `shop_info`.* from `shop_info`
        where 1 = 1
        <if test="name != null and name != '' and name != 'all'">
            and `shop_info`.`name` like concat('%', #{name}, '%')
        </if>
        order by `shop_info`.`time` desc
    </select>

    <select id="findVoById" resultType="com.example.vo.ShopInfoVo">
        select `shop_info`.* from `shop_info`
        where `shop_info`.id = #{id}
    </select>
    <select id="findByLastId" resultType="com.example.vo.ShopInfoVo">
        select `shop_info`.* from `shop_info` order by id desc limit  1
    </select>

</mapper>